{% extends '@SyliusAdmin/layout.html.twig' %}

{% import '@SyliusAdmin/Macro/breadcrumb.html.twig' as breadcrumb %}

{% block title %}{{ 'setono_sylius_qr_code.ui.statistics'|trans }} — {{ qr_code.name }} {{ parent() }}{% endblock %}

{% block content %}
    {{ breadcrumb.crumble([
        { label: 'sylius.ui.administration'|trans, url: path('sylius_admin_dashboard') },
        { label: 'setono_sylius_qr_code.ui.qr_codes'|trans, url: path('setono_sylius_qr_code_admin_qr_code_index') },
        { label: qr_code.name, url: path('setono_sylius_qr_code_admin_qr_code_show', {id: qr_code.id}) },
        { label: 'setono_sylius_qr_code.ui.statistics'|trans }
    ]) }}

    <div class="ui segment">
        <h1 class="ui header">
            <i class="chart bar icon"></i>
            <div class="content">
                {{ 'setono_sylius_qr_code.ui.statistics'|trans }}
                <div class="sub header">{{ qr_code.name }}</div>
            </div>
        </h1>

        <div class="ui four statistics">
            <div class="statistic">
                <div class="value">{{ total_scans }}</div>
                <div class="label">{{ 'setono_sylius_qr_code.ui.total_scans'|trans }}</div>
            </div>
            <div class="statistic">
                <div class="value">{{ scans_last_7_days }}</div>
                <div class="label">{{ 'setono_sylius_qr_code.ui.last_7_days'|trans }}</div>
            </div>
            <div class="statistic">
                <div class="value">{{ scans_last_30_days }}</div>
                <div class="label">{{ 'setono_sylius_qr_code.ui.last_30_days'|trans }}</div>
            </div>
            <div class="statistic">
                <div class="value">{{ scans_last_90_days }}</div>
                <div class="label">{{ 'setono_sylius_qr_code.ui.last_90_days'|trans }}</div>
            </div>
        </div>

        <div class="ui hidden divider"></div>

        <h2 class="ui header">{{ 'setono_sylius_qr_code.ui.scans_over_time'|trans }}</h2>
        <div class="ui segment">
            <canvas id="qr-code-scans-chart" height="100"></canvas>
        </div>

        <div class="ui hidden divider"></div>

        <h2 class="ui header">{{ 'setono_sylius_qr_code.ui.recent_scans'|trans }}</h2>
        <table class="ui celled striped table">
            <thead>
                <tr>
                    <th>{{ 'setono_sylius_qr_code.ui.date_time'|trans }}</th>
                    <th>{{ 'setono_sylius_qr_code.ui.ip_address'|trans }}</th>
                    <th>{{ 'setono_sylius_qr_code.ui.user_agent'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for scan in recent_scans %}
                    <tr>
                        <td>{{ scan.scannedAt ? scan.scannedAt|date('Y-m-d H:i:s') : '-' }}</td>
                        <td>{{ scan.ipAddress }}</td>
                        <td class="collapsing" style="max-width: 40em; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="{{ scan.userAgent }}">
                            {{ scan.userAgent }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="center aligned">—</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        <div class="ui hidden divider"></div>

        <div class="ui buttons">
            <a class="ui button" href="{{ path('setono_sylius_qr_code_admin_qr_code_show', {id: qr_code.id}) }}">
                <i class="eye icon"></i> {{ 'sylius.ui.show'|trans }}
            </a>
            <a class="ui primary button" href="{{ path('setono_sylius_qr_code_admin_qr_code_update', {id: qr_code.id}) }}">
                <i class="edit icon"></i> {{ 'sylius.ui.edit'|trans }}
            </a>
            <a class="ui button" href="{{ path('setono_sylius_qr_code_admin_qr_code_download', {id: qr_code.id}) }}">
                <i class="download icon"></i> {{ 'setono_sylius_qr_code.ui.download'|trans }}
            </a>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    {# Chart.js via CDN. Adopting apps can swap this for a Webpack Encore asset when wiring
       their own build; the QR plugin itself has no frontend build pipeline. #}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.js"></script>
    <script>
        (function () {
            const labels = {{ chart_labels|json_encode|raw }};
            const data = {{ chart_data|json_encode|raw }};
            const ctx = document.getElementById('qr-code-scans-chart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: {{ 'setono_sylius_qr_code.ui.total_scans'|trans|json_encode|raw }},
                        data: data,
                        fill: false,
                        tension: 0.2,
                        borderColor: '#2185d0',
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, ticks: { precision: 0 } }
                    }
                }
            });
        })();
    </script>
{% endblock %}
