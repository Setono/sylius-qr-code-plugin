{#
    Mirrors @SyliusUi/Grid/Action/links.html.twig with one addition: the
    `<i class="dropdown icon"></i>` caret after the label, so the grid row's
    Download button visually advertises that it opens a menu instead of
    looking like a single-action button.
#}
{% set visible = options.visible is defined ? options.visible : true %}

{% if visible %}
    <div class="ui floating dropdown {{ options.class|default('') }} link button">
        {% if options.icon is defined %}<i class="{{ options.icon }} icon"></i>{% endif %}
        <span class="text">{{ action.label|trans }}</span>
        <i class="dropdown icon"></i>
        <div class="menu">
            {% for link in options.links %}
                {% set is_link_visible = link.visible is defined ? link.visible : true %}

                {% if is_link_visible %}
                    {% include '@SyliusUi/Grid/Action/_link.html.twig' %}
                {% endif %}
            {% endfor %}
        </div>
    </div>
{% endif %}
