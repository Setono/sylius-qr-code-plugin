{% extends '@SyliusAdmin/layout.html.twig' %}

{% import '@SyliusAdmin/Macro/breadcrumb.html.twig' as breadcrumb %}

{% set qr_code = resource %}

{% block title %}{{ 'setono_sylius_qr_code.ui.qr_code'|trans }} — {{ qr_code.name }} {{ parent() }}{% endblock %}

{% block content %}
    {{ breadcrumb.crumble([
        { label: 'sylius.ui.administration'|trans, url: path('sylius_admin_dashboard') },
        { label: 'setono_sylius_qr_code.ui.qr_codes'|trans, url: path('setono_sylius_qr_code_admin_qr_code_index') },
        { label: qr_code.name }
    ]) }}

    <div class="ui segment">
        <h1 class="ui header">
            <i class="qrcode icon"></i>
            <div class="content">
                {{ qr_code.name }}
                <div class="sub header">{{ qr_code.slug }}</div>
            </div>
        </h1>

        <div class="ui hidden divider"></div>

        <div class="ui stackable two column grid">
            <div class="five wide column">
                <div class="ui segment">
                    <img src="{{ path('setono_sylius_qr_code_admin_qr_code_download', {id: qr_code.id, format: 'png'}) }}"
                         alt="{{ qr_code.name }}"
                         class="ui centered fluid image">
                </div>
            </div>

            <div class="eleven wide column">
                <table class="ui definition table">
                    <tbody>
                        <tr>
                            <td>{{ 'setono_sylius_qr_code.ui.name'|trans }}</td>
                            <td>{{ qr_code.name }}</td>
                        </tr>
                        <tr>
                            <td>{{ 'setono_sylius_qr_code.ui.slug'|trans }}</td>
                            <td><code>{{ qr_code.slug }}</code></td>
                        </tr>
                        <tr>
                            <td>{{ 'setono_sylius_qr_code.ui.type'|trans }}</td>
                            <td>{% include '@SetonoSyliusQRCodePlugin/admin/qr_code/grid/field/type.html.twig' with {data: qr_code.type} only %}</td>
                        </tr>
                        <tr>
                            <td>{{ 'sylius.ui.enabled'|trans }}</td>
                            <td>
                                {% if qr_code.enabled %}
                                    <span class="ui label green">{{ 'sylius.ui.enabled'|trans }}</span>
                                {% else %}
                                    <span class="ui label red">{{ 'sylius.ui.disabled'|trans }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% if qr_code.type == constant('Setono\\SyliusQRCodePlugin\\Model\\QRCodeInterface::TYPE_PRODUCT') and qr_code.product is not null %}
                            <tr>
                                <td>{{ 'setono_sylius_qr_code.ui.product'|trans }}</td>
                                <td>
                                    <a href="{{ path('sylius_admin_product_update', {id: qr_code.product.id}) }}">
                                        {{ qr_code.product.name }}
                                    </a>
                                </td>
                            </tr>
                        {% endif %}
                        {% if qr_code.type == constant('Setono\\SyliusQRCodePlugin\\Model\\QRCodeInterface::TYPE_TARGET_URL') %}
                            <tr>
                                <td>{{ 'setono_sylius_qr_code.ui.target_url'|trans }}</td>
                                <td><a href="{{ qr_code.targetUrl }}" target="_blank" rel="noopener">{{ qr_code.targetUrl }}</a></td>
                            </tr>
                        {% endif %}
                        <tr>
                            <td>{{ 'setono_sylius_qr_code.ui.redirect_url'|trans }}</td>
                            <td><a href="{{ path('setono_sylius_qr_code_redirect', {slug: qr_code.slug}) }}" target="_blank" rel="noopener">{{ path('setono_sylius_qr_code_redirect', {slug: qr_code.slug}) }}</a></td>
                        </tr>
                        <tr>
                            <td>{{ 'setono_sylius_qr_code.ui.error_correction_level'|trans }}</td>
                            <td>{{ qr_code.errorCorrectionLevel }}</td>
                        </tr>
                        <tr>
                            <td>{{ 'setono_sylius_qr_code.ui.utm_source'|trans }}</td>
                            <td>{{ qr_code.utmSource|default('-') }}</td>
                        </tr>
                        <tr>
                            <td>{{ 'setono_sylius_qr_code.ui.utm_medium'|trans }}</td>
                            <td>{{ qr_code.utmMedium|default('-') }}</td>
                        </tr>
                        <tr>
                            <td>{{ 'setono_sylius_qr_code.ui.utm_campaign'|trans }}</td>
                            <td>{{ qr_code.utmCampaign|default('-') }}</td>
                        </tr>
                        <tr>
                            <td>{{ 'setono_sylius_qr_code.ui.scans'|trans }}</td>
                            <td>{{ qr_code.scansCount }}</td>
                        </tr>
                        <tr>
                            <td>{{ 'sylius.ui.created_at'|trans }}</td>
                            <td>{{ qr_code.createdAt ? qr_code.createdAt|date('Y-m-d H:i') : '-' }}</td>
                        </tr>
                        <tr>
                            <td>{{ 'sylius.ui.last_updated'|trans }}</td>
                            <td>{{ qr_code.updatedAt ? qr_code.updatedAt|date('Y-m-d H:i') : '-' }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="ui hidden divider"></div>

        <div class="ui buttons">
            <a class="ui primary button" href="{{ path('setono_sylius_qr_code_admin_qr_code_update', {id: qr_code.id}) }}">
                <i class="edit icon"></i> {{ 'sylius.ui.edit'|trans }}
            </a>
            <div class="ui floating dropdown button">
                <i class="download icon"></i>
                <span class="text">{{ 'setono_sylius_qr_code.ui.download'|trans }}</span>
                <i class="dropdown icon"></i>
                <div class="menu">
                    <a class="item" href="{{ path('setono_sylius_qr_code_admin_qr_code_download', {id: qr_code.id, format: 'png'}) }}">
                        <i class="image icon"></i> PNG
                    </a>
                    <a class="item" href="{{ path('setono_sylius_qr_code_admin_qr_code_download', {id: qr_code.id, format: 'svg'}) }}">
                        <i class="image outline icon"></i> SVG
                    </a>
                    <a class="item" href="{{ path('setono_sylius_qr_code_admin_qr_code_download', {id: qr_code.id, format: 'pdf'}) }}">
                        <i class="file pdf icon"></i> PDF
                    </a>
                </div>
            </div>
            <a class="ui button" href="{{ path('setono_sylius_qr_code_admin_qr_code_stats', {id: qr_code.id}) }}">
                <i class="chart bar icon"></i> {{ 'setono_sylius_qr_code.ui.see_stats'|trans }}
            </a>
        </div>
    </div>
{% endblock %}
