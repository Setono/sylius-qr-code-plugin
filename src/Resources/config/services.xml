<?xml version="1.0" encoding="UTF-8" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
                               https://symfony.com/schema/dic/services/services-1.0.xsd">

    <!--
        Plugin services are declared explicitly (no autowire / autoconfigure / resource-based auto-discovery).
        See CLAUDE.md "Service Definitions in Plugins" for the rationale.

        This file is a dispatcher. Services themselves live in per-folder files under
        `src/Resources/config/services/<folder>.xml`, one file per root folder under `src/` that contains
        services. For example:

            src/Resolver/           -> src/Resources/config/services/resolver.xml
            src/Generator/          -> src/Resources/config/services/generator.xml
            src/Tracker/            -> src/Resources/config/services/tracker.xml
            src/Action/             -> src/Resources/config/services/action.xml
            src/Form/               -> src/Resources/config/services/form.xml
            src/Menu/               -> src/Resources/config/services/menu.xml
            src/Validator/          -> src/Resources/config/services/validator.xml
            ...

        Folders that don't contain services (Model/, Resources/, DependencyInjection/) don't get a file.

        Each per-folder file uses the same XML format. Import them below via `<imports>`. Service IDs use
        the fully qualified class name; interfaces are registered as `alias` entries pointing at the
        concrete implementation, e.g.:

            <service id="Setono\SyliusQRCodePlugin\Generator\QRCodeGenerator">
                <argument type="service" id="..."/>
            </service>
            <service id="Setono\SyliusQRCodePlugin\Generator\QRCodeGeneratorInterface"
                     alias="Setono\SyliusQRCodePlugin\Generator\QRCodeGenerator"/>
    -->

    <imports>
        <import resource="services/event_listener.xml"/>
        <import resource="services/factory.xml"/>
        <import resource="services/form.xml"/>
    </imports>

    <services/>

</container>
