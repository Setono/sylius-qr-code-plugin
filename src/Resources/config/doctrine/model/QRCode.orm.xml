<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <!--
        The base QRCode resource uses Single Table Inheritance. The discriminator-map is NOT
        declared here because the concrete subtype classes are only known at runtime (they
        come from `sylius_resource.resources.*.classes.model`). A Doctrine loadClassMetadata
        listener (QRCodeDiscriminatorMapListener) populates the map when Doctrine loads this
        metadata. This keeps the plugin compatible with apps that override a subtype class.
    -->
    <mapped-superclass name="Setono\SyliusQRCodePlugin\Model\QRCode"
                       table="setono_sylius_qr_code__qr_code"
                       inheritance-type="SINGLE_TABLE">
        <discriminator-column name="type" type="string" length="20"/>

        <!--
            slug is already unique (declared on the field below) so it gets a UNIQUE index
            automatically — that covers findOneBySlug / findOneEnabledBySlug, which is the hot
            path hit on every redirect. We additionally index `type` (the STI discriminator) for
            the admin grid's Type filter.
        -->
        <indexes>
            <index name="setono_sylius_qr_code_type_idx" columns="type"/>
        </indexes>

        <id name="id" type="integer" column="id">
            <generator strategy="AUTO"/>
        </id>

        <field name="name" type="string" length="255"/>
        <field name="slug" type="string" length="100" unique="true"/>
        <field name="enabled" type="boolean"/>
        <field name="embedLogo" type="boolean" column="embed_logo"/>
        <field name="errorCorrectionLevel" type="string" length="1" column="error_correction_level"/>
        <field name="utmSource" type="string" length="50" column="utm_source" nullable="true"/>
        <field name="utmMedium" type="string" length="50" column="utm_medium" nullable="true"/>
        <field name="utmCampaign" type="string" length="100" column="utm_campaign" nullable="true"/>

        <field name="createdAt" type="datetime_immutable" column="created_at">
            <gedmo:timestampable on="create"/>
        </field>
        <field name="updatedAt" type="datetime_immutable" column="updated_at">
            <gedmo:timestampable on="update"/>
        </field>

        <one-to-many field="scans" target-entity="Setono\SyliusQRCodePlugin\Model\QRCodeScan" mapped-by="qrCode" fetch="EXTRA_LAZY">
            <cascade>
                <cascade-remove/>
            </cascade>
        </one-to-many>
    </mapped-superclass>

</doctrine-mapping>
