<?xml version="1.0" encoding="UTF-8" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
                               https://symfony.com/schema/dic/services/services-1.0.xsd">

    <!--
        QRCodeController (the ResourceController subclass dispatching subtype update routes)
        is auto-registered by Sylius Resource Bundle from classes.controller, so it has no
        entry here. Only controllers we register explicitly live in this file.
    -->
    <services>
        <service id="Setono\SyliusQRCodePlugin\Controller\RedirectAction" public="true">
            <argument type="service" id="setono_sylius_qr_code.repository.qr_code"/>
            <argument type="service" id="Setono\SyliusQRCodePlugin\Resolver\TargetUrlResolverInterface"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="logger"/>
        </service>

        <service id="Setono\SyliusQRCodePlugin\Controller\DownloadAction" public="true">
            <argument type="service" id="setono_sylius_qr_code.repository.qr_code"/>
            <argument type="service" id="sylius.repository.channel"/>
            <argument type="service" id="Setono\SyliusQRCodePlugin\Channel\DefaultChannelResolverInterface"/>
            <argument type="service" id="Setono\SyliusQRCodePlugin\Generator\QRCodeGeneratorInterface"/>
        </service>

        <service id="Setono\SyliusQRCodePlugin\Controller\StatsAction" public="true">
            <argument type="service" id="setono_sylius_qr_code.repository.qr_code"/>
            <argument type="service" id="setono_sylius_qr_code.repository.qr_code_scan"/>
            <argument type="service" id="twig"/>
        </service>

        <service id="Setono\SyliusQRCodePlugin\Controller\BulkGenerateQRCodesAction" public="true">
            <argument type="service" id="sylius.repository.product"/>
            <argument type="service" id="setono_sylius_qr_code.repository.qr_code"/>
            <argument type="service" id="Setono\SyliusQRCodePlugin\Factory\ProductRelatedQRCodeFactoryInterface"/>
            <argument type="service" id="router"/>
            <argument>%setono_sylius_qr_code.logo.path%</argument>
            <argument type="service" id="doctrine"/>
        </service>
    </services>
</container>
