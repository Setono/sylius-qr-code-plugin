<?xml version="1.0" encoding="UTF-8" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
                               https://symfony.com/schema/dic/services/services-1.0.xsd">

    <!--
        CompositeTargetUrlResolver is populated by setono/composite-compiler-pass from every
        service tagged `setono_sylius_qr_code.target_url_resolver` — the per-subtype resolvers
        that return the base URL. UtmTargetUrlResolver decorates the TargetUrlResolverInterface
        alias to append UTM parameters onto whatever the underlying implementation returns.
        Decorating the interface (not the concrete composite) keeps the plugin extensible:
        adopting apps that swap in their own TargetUrlResolverInterface implementation still get
        UTM decoration on top for free.
    -->
    <services>
        <service id="Setono\SyliusQRCodePlugin\Resolver\CompositeTargetUrlResolver"/>

        <service id="Setono\SyliusQRCodePlugin\Resolver\TargetUrlResolverInterface"
                 alias="Setono\SyliusQRCodePlugin\Resolver\CompositeTargetUrlResolver"/>

        <service id="Setono\SyliusQRCodePlugin\Resolver\UtmTargetUrlResolver"
                 decorates="Setono\SyliusQRCodePlugin\Resolver\TargetUrlResolverInterface"
                 decoration-priority="100">
            <argument type="service" id="Setono\SyliusQRCodePlugin\Resolver\UtmTargetUrlResolver.inner"/>
        </service>

        <service id="Setono\SyliusQRCodePlugin\Resolver\TargetUrlQRCodeResolver">
            <tag name="setono_sylius_qr_code.target_url_resolver"/>
        </service>

        <service id="Setono\SyliusQRCodePlugin\Resolver\ProductRelatedQRCodeResolver">
            <argument type="service" id="sylius.context.channel"/>
            <argument type="service" id="router"/>
            <tag name="setono_sylius_qr_code.target_url_resolver"/>
        </service>
    </services>
</container>
