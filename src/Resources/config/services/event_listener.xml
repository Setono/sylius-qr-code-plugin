<?xml version="1.0" encoding="UTF-8" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
                               https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Setono\SyliusQRCodePlugin\EventListener\AdminMenuListener">
            <tag name="kernel.event_listener" event="sylius.menu.admin.main" method="__invoke"/>
        </service>

        <service id="Setono\SyliusQRCodePlugin\EventListener\Doctrine\QRCodeDiscriminatorMapListener">
            <argument>%setono_sylius_qr_code.resources%</argument>
            <tag name="doctrine.event_listener" event="loadClassMetadata"/>
        </service>
    </services>
</container>
