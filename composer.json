{
    "name": "setono/sylius-qr-code-plugin",
    "description": "QR code generation, management, and scan tracking plugin for Sylius.",
    "license": "MIT",
    "type": "sylius-plugin",
    "keywords": [
        "sylius",
        "sylius-plugin",
        "qr-code",
        "qr"
    ],
    "require": {
        "php": ">=8.1",
        "doctrine/collections": "^1.8 || ^2.0",
        "doctrine/orm": "^2.15 || ^3.0",
        "doctrine/persistence": "^2.5 || ^3.0",
        "endroid/qr-code": "^5.0",
        "gedmo/doctrine-extensions": "^3.11",
        "league/uri": "^6.8 || ^7.8",
        "league/uri-interfaces": "^2.3 || ^7.8",
        "psr/log": "^1.1 || ^2.0 || ^3.0",
        "setono/composite-compiler-pass": "^1.2",
        "setono/doctrine-orm-trait": "^1.2",
        "sylius/channel": "^1.0",
        "sylius/core": "^1.0",
        "sylius/core-bundle": "^1.0",
        "sylius/product": "^1.0",
        "sylius/product-bundle": "^1.0",
        "sylius/resource-bundle": "^1.0",
        "sylius/ui-bundle": "^1.0",
        "symfony/config": "^5.4 || ^6.4",
        "symfony/dependency-injection": "^5.4 || ^6.4",
        "symfony/event-dispatcher": "^5.4 || ^6.4",
        "symfony/event-dispatcher-contracts": "^2.5 || ^3.0",
        "symfony/form": "^5.4 || ^6.4",
        "symfony/http-foundation": "^5.4 || ^6.4",
        "symfony/http-kernel": "^5.4 || ^6.4",
        "symfony/routing": "^5.4 || ^6.4",
        "symfony/string": "^5.4 || ^6.4",
        "twig/twig": "^3.0",
        "webmozart/assert": "^1.11"
    },
    "require-dev": {
        "api-platform/core": "^2.7.16",
        "babdev/pagerfanta-bundle": "^3.8",
        "behat/behat": "^3.14",
        "dama/doctrine-test-bundle": "^7.0 || ^8.0",
        "doctrine/doctrine-bundle": "^2.11",
        "jms/serializer-bundle": "^4.2",
        "lexik/jwt-authentication-bundle": "^2.17",
        "setasign/fpdf": "^1.8.6",
        "setono/sylius-plugin-pack": "~1.14.1",
        "sylius-labs/polyfill-symfony-security": "^1.1.2",
        "symfony/browser-kit": "^5.4 || ^6.4",
        "symfony/debug-bundle": "^5.4 || ^6.4",
        "symfony/dotenv": "^5.4 || ^6.4",
        "symfony/intl": "^5.4 || ^6.4",
        "symfony/property-info": "^5.4 || ^6.4",
        "symfony/serializer": "^5.4 || ^6.4",
        "symfony/web-profiler-bundle": "^5.4 || ^6.4",
        "symfony/webpack-encore-bundle": "^1.17.2",
        "willdurand/negotiation": "^3.1"
    },
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Setono\\SyliusQRCodePlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Setono\\SyliusQRCodePlugin\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Application/Kernel.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "infection/extension-installer": true,
            "phpstan/extension-installer": true,
            "symfony/thanks": false
        },
        "audit": {
            "block-insecure": false
        },
        "sort-packages": true
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "check-style": "ecs check",
        "fix-style": "ecs check --fix",
        "phpunit": "phpunit"
    }
}
